<section class="relative border-b border-[#dce5da]">
    <div class="section-shell grid gap-12 py-16 md:py-20 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
        <div>
            <p class="inline-flex rounded-md border border-[#bfd7c9] bg-[#eef8f2] px-3 py-1 font-mono text-xs font-semibold uppercase tracking-normal text-[#0f766e]">
                CLI-first encrypted sharing
            </p>
            <h1 class="mt-7 max-w-3xl text-5xl font-semibold leading-[1.04] tracking-normal text-[#13201d] md:text-6xl">
                Share encrypted files from your terminal
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-[#52625d]">
                Upload a file or secret, get a temporary encrypted link, and send it to a teammate, client, or another device.
            </p>
            <div class="mt-9 flex flex-col gap-3 sm:flex-row">
                <a href="#install" class="focus-ring inline-flex justify-center rounded-md bg-[#13201d] px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#223530]">
                    Install CLI
                </a>
                <a href="https://github.com/lampego/SecShare" target="_blank" rel="noopener noreferrer" class="focus-ring inline-flex justify-center rounded-md border border-[#cbd8cf] bg-white px-5 py-3 text-sm font-semibold text-[#13201d] shadow-sm transition hover:border-[#9bb5aa]">
                    View on GitHub
                </a>
            </div>
            <dl class="mt-10 grid max-w-2xl grid-cols-3 gap-3 text-sm">
                <div class="rounded-lg border border-[#dce5da] bg-white/70 p-4">
                    <dt class="font-mono text-xs uppercase text-[#6b7c75]">Setup</dt>
                    <dd class="mt-1 font-semibold text-[#13201d]">Install once</dd>
                </div>
                <div class="rounded-lg border border-[#dce5da] bg-white/70 p-4">
                    <dt class="font-mono text-xs uppercase text-[#6b7c75]">Links</dt>
                    <dd class="mt-1 font-semibold text-[#13201d]">Expire</dd>
                </div>
                <div class="rounded-lg border border-[#dce5da] bg-white/70 p-4">
                    <dt class="font-mono text-xs uppercase text-[#6b7c75]">Receive</dt>
                    <dd class="mt-1 font-semibold text-[#13201d]">Browser or CLI</dd>
                </div>
            </dl>
        </div>

        <div id="example" class="rounded-lg border border-[#263a36] bg-[#101816] p-4 shadow-2xl shadow-[#4b665d]/20 terminal-grid">
            <div class="flex items-center justify-between border-b border-white/10 pb-3">
                <div class="flex gap-2" aria-hidden="true">
                    <span class="h-3 w-3 rounded-full bg-[#f0a35b]"></span>
                    <span class="h-3 w-3 rounded-full bg-[#e3d65c]"></span>
                    <span class="h-3 w-3 rounded-full bg-[#74c69d]"></span>
                </div>
                <span class="font-mono text-xs text-[#8ba39b]">secshare upload</span>
            </div>
            <div class="space-y-6 p-2 pt-6 font-mono text-sm leading-7 text-[#d7f5ea] sm:text-base">
                <p><span class="text-[#74c69d]">$</span> secshare upload ./report.zip --expires 24h</p>
                <div class="rounded-md border border-white/10 bg-black/20 p-4">
                    <p class="text-[#8ba39b]">Link ready:</p>
                    <p class="mt-3 break-all">
                        <span class="text-[#c4f1da]">https://secshare.me/f/019f...</span><span class="text-[#f0a35b]">#decryption-key</span>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
