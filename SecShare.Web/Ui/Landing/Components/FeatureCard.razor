<article class="rounded-lg border border-[#dce5da] bg-white p-5 shadow-sm">
    <h3 class="text-lg font-semibold text-[#13201d]">@Title</h3>
    <p class="mt-3 text-sm leading-6 text-[#52625d]">@Text</p>
</article>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Text { get; set; } = string.Empty;
}
