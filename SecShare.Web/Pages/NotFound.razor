@page "/not-found"
@layout MainLayout

<PageTitle>Not found - SecShare</PageTitle>

<main class="flex min-h-screen items-center justify-center bg-[#f7f8f5] px-6 text-[#13201d]">
    <section class="max-w-md text-center">
        <a href="/" class="inline-flex items-center gap-3 font-semibold text-[#13201d]">
            <img src="images/logos/logo-horizontal.svg" alt="SecShare" class="h-9 w-auto" />
        </a>
        <h1 class="mt-8 text-4xl font-semibold tracking-normal">Page not found</h1>
        <p class="mt-4 text-base leading-7 text-[#52625d]">
            The requested page does not exist yet. SecShare currently ships the landing page and CLI install assets.
        </p>
        <a href="/" class="focus-ring mt-8 inline-flex rounded-md bg-[#13201d] px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#223530]">
            Back to home
        </a>
    </section>
</main>
