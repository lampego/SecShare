<section class="border-b border-[#dce5da] py-14">
    <div class="section-shell">
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
            <div>
                <p class="font-mono text-sm font-semibold uppercase tracking-normal text-[#0f766e]">Browser</p>
                <h2 class="mt-3 text-3xl font-semibold tracking-normal text-[#13201d] md:text-4xl">
                    Use SecShare in your browser
                </h2>
                <p class="mt-5 text-lg leading-8 text-[#52625d]">
                    No CLI installed? Create or open encrypted links directly in the browser.
                </p>
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
                <article class="rounded-lg border border-[#dce5da] bg-white p-5 shadow-sm">
                    <h3 class="font-semibold text-[#13201d]">Create encrypted link</h3>
                    <p class="mt-2 text-sm leading-6 text-[#52625d]">
                        Upload files or text, encrypt them locally, and get a temporary link to share.
                    </p>
                    <a href="/upload" class="focus-ring mt-5 inline-flex justify-center rounded-md bg-[#13201d] px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-[#223530]">
                        Upload files
                    </a>
                </article>

                <article class="rounded-lg border border-[#dce5da] bg-white p-5 shadow-sm">
                    <h3 class="font-semibold text-[#13201d]">Open received link</h3>
                    <p class="mt-2 text-sm leading-6 text-[#52625d]">
                        Paste a SecShare link, decrypt it locally, and download the file.
                    </p>
                    <a href="/receive" class="focus-ring mt-5 inline-flex justify-center rounded-md border border-[#cbd8cf] bg-white px-4 py-2 text-sm font-semibold text-[#13201d] shadow-sm transition hover:border-[#9bb5aa]">
                        Receive file
                    </a>
                </article>
            </div>
        </div>
    </div>
</section>
