<section id="cli" class="border-b border-[#dce5da] py-16">
    <div class="section-shell grid gap-10 lg:grid-cols-[0.82fr_1.18fr]">
        <div>
            <p class="font-mono text-sm font-semibold uppercase tracking-normal text-[#0f766e]">CLI examples</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-normal text-[#13201d] md:text-4xl">Share from the terminal</h2>
            <p class="mt-5 text-lg leading-8 text-[#52625d]">
                SecShare is built for small, everyday handoffs: logs, configs, archives, database dumps, private documents, and one-time secrets.
            </p>
            <p class="mt-4 text-lg leading-8 text-[#52625d]">
                Upload the file, send the encrypted link, and let it expire when the job is done.
            </p>
        </div>

        <div class="space-y-4">
            <CodeExample Title="Upload file" Command="secshare upload ./report.zip --expires 24h" />
            <CodeExample Title="Upload secret" Command="secshare upload &quot;DATABASE_URL=postgres://...&quot; --text --expires 1h --downloads 1" />
            <CodeExample Title="Download" Command="secshare get &quot;https://secshare.me/f/019f...#key&quot;" />
        </div>
    </div>
</section>
